/** Global select variables */
const allButtons = document.querySelectorAll('.has-submenu > button');
const allSubMenus = document.querySelectorAll('.submenu');
const menu = document.querySelector("#topnav");
const mobileMenuTrigger = document.querySelector("#mobileMenuTrigger");
const navLinks = document.querySelector("#navigationLinks");
const main = document.querySelector("#content");
const footer = document.querySelector("#site-footer");

function findButtonForSubmenu(submenuId) {
    let matchingButtonId = null;
    allButtons.forEach(function (button) {
        const controls = button.getAttribute("aria-controls");
        if (controls === submenuId) {
            matchingButtonId = button.id;
            return;
        }
    });
    return matchingButtonId;
}

function toggleSubNav(eId) {
    try {
        if (eId !== "") {
            //Get the button element
            const toggle = document.getElementById(eId);
            // Get what the button controls
            const toggleControls = toggle.getAttribute("aria-controls");
            // Get the submenu that the button controls
            const subMenu = document.getElementById(toggleControls);
            console.log(subMenu);

            if (toggle.getAttribute("aria-expanded") === "false") {
                // Close all the other submenus
                allButtons.forEach(function (button) {
                    button.setAttribute('aria-expanded', 'false');
                });
                // Show the submenu associated with the button
                toggle.setAttribute("aria-expanded", "true");
            } else {
                // Close the submenu associated with the button
                toggle.setAttribute("aria-expanded", "false");
            }

            if (subMenu.style.display === "none") {
                // Hide the other submenus
                allSubMenus.forEach(function (menu) {
                    menu.style.display = "none";
                });
                // Show the submenu associated with the button
                subMenu.style.display = "block";
                subMenu.classList.add('open');
            } else {
                // Hide the submenu associated with the button
                subMenu.style.display = "none";
                subMenu.classList.remove('open');
            }
        }
    } catch (error) {
        console.log(`toggleSubNav() error: ${error}`)
    }
}

function closeMobileMenu() {
    console.log('closeMobileMenu()');
    mobileMenuTrigger.setAttribute('aria-expanded', 'false');
    menu.classList.remove('responsive');

    // make sure the skip link is reachable
    skipLink.style.display = "block";

    // Show the content and footer
    main.style.display = "block";
    footer.style.display = "block";

    // Change the X icon to a hamburger
    mobileMenuTrigger.innerHTML = '<i class="fa-solid fa-bars" style="font-size: 2.5em"></i>';
}

function openMobileMenu() {
    console.log('openMobileMenu()');
    mobileMenuTrigger.setAttribute('aria-expanded', 'true');
    menu.classList.add('responsive');

    // Hide the buttons
    allButtons.forEach(function (button) {
        button.setAttribute('aria-expanded', 'false');
        button.style.display = "none";
    });

    // Hide the main content and footer
    main.style.display = "none";
    footer.style.display = "none";

    // Change the hamburger icon to an X
    mobileMenuTrigger.innerHTML = '<i class="fa-solid fa-x" style="font-size: 2.5em;"></i>';

    // hide the skip link if menu is open so you can't back tab to it
    skipLink.style.display = "none";
}

/** Event handlers */
allButtons.forEach(function (button) {
    button.addEventListener("click", function () {
        toggleSubNav(this.id);
    });
    // if the submenu is expanded and the the user clicks escape, close the submenu
    button.addEventListener("keydown", function (event) {
        if (event.key === 'Escape') {
            // see if the submenu is expanded using the button's aria-expanded attribute
            if (this.getAttribute("aria-expanded") === "true") {
                toggleSubNav(this.id);
            }
        }
        // Without this. the menu will stay open if someone tabs to the sub-menu button, presses the enter/return key to open the menu,
        // and then hits shift+tab to go back through the navigation items without going into the sub-menu.
        if (event.key === 'Tab' && event.shiftKey) {
            // if the user has opened the submenu, close it
            if (this.getAttribute("aria-expanded") === "true") {
                toggleSubNav(this.id);
            }
        }
    });
});

allSubMenus.forEach(function (menu) {
    // track if the submenu is closing with escape; if escape is fired, it also fires focusout, so we need to know if it was fired by escape or not
    isClosingWithEscape = false;
    menu.addEventListener("focusout", function (event) {
        // should only fire on desktop
        if (!menu.classList.contains('responsive')) {
            // Event bubbling: https://gomakethings.com/detecting-when-focus-leaves-a-group-of-elements-with-vanilla-js/
            if (menu.contains(event.relatedTarget)) {
                return;
            } else if (!isClosingWithEscape) {
                // get the button that aria controls this submenu
                const toggleButtonId = findButtonForSubmenu(this.id);
                toggleSubNav(toggleButtonId);
            }
        }
    });
    menu.addEventListener("keydown", function (event) {
        // should only fire on desktop
        if (!menu.classList.contains('responsive')) {
            if (event.key === 'Escape') {
                isClosingWithEscape = true;
                // get the button that aria controls this submenu
                const toggleButtonId = findButtonForSubmenu(this.id);
                toggleSubNav(toggleButtonId);
            }
        }
    });
});

mobileMenuTrigger.addEventListener('click', () => {
    navLinks.classList.toggle('active');
    mobileMenuTrigger.classList.toggle('active');
    // Toggle Aria-Expanded Attribute True / False
    if (mobileMenuTrigger.classList.contains('active')) {
        openMobileMenu();
    } else {
        closeMobileMenu();
    }
});

// Use escape to close mobile menu
// Should only fire when the mobile menu is open
document.addEventListener('keydown', (event) => {
    if (mobileMenu.classList.contains('active')) {
        if (event.key === 'Escape') {
            mobileMenu.classList.remove('active');
            mobileMenuTrigger.classList.remove('active');
            closeMobileMenu();
        }
    }
});


// if the screen size is adjusted from mobile to desktop, make sure the menu can be accessed
addEventListener("resize", (event) => {
    if (window.innerWidth > 600) {
        mobileMenuTrigger.classList.remove('active');
        // show the buttons
        allButtons.forEach(function (button) {
            button.setAttribute('aria-expanded', 'false');
            button.style.display = "block";
        });
        closeMobileMenu();
    }
});
}

